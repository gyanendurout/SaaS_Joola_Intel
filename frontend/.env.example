# Supabase — required for all data reads and writes
# Get these from: https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Supabase service-role key — server-side writes only, NEVER expose to client
# Only needed in Python data-pipeline scripts (scripts/.env), not in Next.js
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# OpenAI — server-side API routes only (keyword research, content generation)
# Must NOT have NEXT_PUBLIC_ prefix — this is a server secret
OPENAI_API_KEY=sk-...

# Apify — used by Python scraper pipeline (scripts/.env), not Next.js
APIFY_TOKEN=<apify-token>

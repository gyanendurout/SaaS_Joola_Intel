#!/bin/sh
# Pre-push gate — runs the frontend regression suite before allowing a push.
# Bypass with: git push --no-verify  (use only when you know what you're doing).
#
# After the 2026-05-24 reorg, the Next.js app + qa/ live under frontend/, so
# husky must cd in before invoking the regression script.

echo ""
echo "[pre-push] running frontend qa/regression.ps1 -SkipBuild -Continue..."
repo_root=$(git rev-parse --show-toplevel)
powershell.exe -ExecutionPolicy Bypass -File "$repo_root/frontend/qa/regression.ps1" -SkipBuild -Continue
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "[pre-push] regression failed (exit $status). Push blocked."
  echo "[pre-push] fix the issue, or pass --no-verify to bypass."
  exit 1
fi

# Confirm the flag file is fresh (< 1 hour old).
flag="/c/tmp/joola-intel-qa-passed.flag"
if [ ! -f "$flag" ]; then
  echo "[pre-push] WARN: QA flag missing — regression may have skipped critical stages."
fi

echo "[pre-push] regression PASS — push allowed."
exit 0
